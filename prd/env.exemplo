# ----------------------------------------------------------------------------
# IA — Entrevista 360, Forja de Copy e Oráculo
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sua_chave_aqui
ANTHROPIC_MODEL=claude-sonnet-4-6
# Embeddings para o RAG do Oráculo (ajuste a dimensão do vetor no SQL ao modelo)
OPENAI_API_KEY=sua_chave_aqui
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ----------------------------------------------------------------------------
# Frescor do Oráculo — Firecrawl (re-scrape das políticas da Meta)
# ----------------------------------------------------------------------------
FIRECRAWL_API_KEY=your-firecrawl-key
FIRECRAWL_BASE_URL=https://api.firecrawl.dev        # ou sua instância self-hosted
# Protege o endpoint de cron que dispara o re-scrape/re-embed
CRON_SECRET=generate-a-long-random-string

# ----------------------------------------------------------------------------
# Orquestração — n8n (export de funil e automações)
# ----------------------------------------------------------------------------
N8N_BASE_URL=https://n8n.seudominio.com
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_URL=https://n8n.seudominio.com/webhook/ea360

# ----------------------------------------------------------------------------
# Execução de Ads — Meta Marketing API + WhatsApp Cloud API (nó executor)
# ----------------------------------------------------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-long-lived-token
META_AD_ACCOUNT_ID=act_000000000000000
META_GRAPH_API_VERSION=v21.0

WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_CLOUD_API_TOKEN=your-cloud-api-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token       # eco na verificação do webhook
WHATSAPP_WEBHOOK_SECRET=your-webhook-app-secret       # validação de assinatura

# ----------------------------------------------------------------------------
# Observabilidade e e-mail (opcionais)
# ----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
RESEND_API_KEY=
